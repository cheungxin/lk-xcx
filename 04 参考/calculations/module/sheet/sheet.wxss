.module-container{
   position: fixed;
   top: 0;
   left: 0;
   z-index:99;
   width:100vw;
   height:100vh;
   background: var(--page-black-cover);
}
.module-content{
  position: fixed;
  bottom:0;
  left: 0;
}
.module-body{ 
    width:750rpx;
    background-color:var(--white);
    border-top-left-radius: 30rpx;
    border-top-right-radius: 30rpx; 
}
.moddule-header{
  display: flex; 
  justify-content: center;
  height:86rpx;
  line-height: 86rpx;
  position: relative;
} 
.moddule-title{ 
  color:var(--text-color-primary);
}
.moddule-close{
  position: absolute;
  top:5rpx;
  right:5rpx;
  width:80rpx; 
} 
.moddule-close .iconfont{
  font-size:40rpx;
  color:var(--icon-text-color-primary); 
}
.divider{
  width:680rpx; 
  margin: 0 auto;
  height: 1rpx;
  background-color: var(--label-outline-color); 
}
.moddule-info{
  width:680rpx;
  height: 80rpx;
  line-height:80rpx;
  margin:0 auto;
  display:flex;
  font-size: 30rpx; 
  color: #343C45; 
  justify-content: space-between;
}
.number-info{
  width:300rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}  
.number-info .done::before,.number-info .undo::before{
  content: ""; 
  width:20rpx;
  height:20rpx;
  border-radius:15rpx;
  margin-right:10rpx;
  background-color: var(--color-primary);
  display: inline-block; /* optional */
  text-align: center; /* optional */ 
  line-height:60rpx; 
} 
.number-info .undo::before{ 
  border:var(--label-outline-color) 1rpx solid;
  background-color: var(--label-background-normal);
} 
.module-section{
  display:flex;
  flex-direction:column;   
}  
.cells-box{
    width: 660rpx;
    height: 100%;
    height: auto;
    margin:0 auto;
    display: flex;
    justify-content:flex-start;
    flex-wrap: wrap;
    padding-top:10rpx;
    padding-bottom:140rpx; 
}
.cells-item{
  font-size: 28rpx;
  width: 78rpx;
  height: 78rpx;
  border:var(--label-outline-color) 1rpx solid;
  background-color: var(--label-background-normal);
  border-radius: 50%;
  text-align: center;
  line-height: 78rpx;
  margin: 25rpx;
  font-weight: 300;
  color: var(--text-color-primary);
} 

.cells-item.answered{
  background-color:var(--color-primary); 
  color:var(--white); 
  border: 1rpx solid var(--color-primary);
} 

.button-container { 
   width:100%; 
   padding:10rpx  0 36rpx;
   background-color:var(--white); 
   display: flex;
   justify-content: space-around;
  } 
  .button {
    width:320rpx;
    height: 70rpx;
    line-height: 70rpx;
    text-align: center;
    border-radius: 50rpx;
    font-size:28rpx;
    color:var(--white);
  } 
  .cancel {
    color: var(--icon-text-color-primary);
    background-color:var(--label-background-normal);
  }
  
  .submit {
    color:var(--white);
    background-color:var(--color-primary); 
  }
  .iconfont{
    font-size:28rpx;
    padding-right: 20rpx;
  }



  @-webkit-keyframes fadeInUpBig {
    from {
      opacity: 0;
      -webkit-transform: translate3d(0, 2000rpx, 0);
      transform: translate3d(0, 2000rpx, 0);
    }
  
    to {
      opacity: 1;
      -webkit-transform: none;
      transform: none;
    }
  }
  
  @keyframes fadeInUpBig {
    from {
      opacity: 0;
      -webkit-transform: translate3d(0, 2000rpx, 0);
      transform: translate3d(0, 2000rpx, 0);
    }
  
    to {
      opacity: 1;
      -webkit-transform: none;
      transform: none;
    }
  }
  
  .fadeInUpBig {
    -webkit-animation-duration: .5s;
    animation-duration: .5s;
    -webkit-animation-fill-mode: both;
    animation-fill-mode: both;
    -webkit-animation-name: fadeInUpBig;
    animation-name: fadeInUpBig;
  }