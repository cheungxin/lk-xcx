@media screen and (min-device-width: 768px) {
    .xs {
        width: 2px;
        height: 2px;
      }
      .s {
        width: 4px;
        height: 4px;
      }
      .m {
        width: 10px;
        height:  10px;
      }
      .l {
        width: 15px;
        height:15px;
      }
      .xl {
        width: 20px;
        height: 20px;
      }
      .xxl{
        width: 30px;
        height: 30px;
      }
      .xxxl{
        width: 40px;
        height: 40px;
      }
      .xxxxl{
        width: 50px;
        height: 50px;
      }
    .thickness-item { 
        margin-left:5px;
      }
}