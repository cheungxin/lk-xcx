 /* pages/draw/draw.wxss */
 
.canvas-pop{ 
  position: fixed; 
  left: 0;
  z-index: 99;
  min-height: 100vh;
  width: 100vw;  
}
.canvas{
  width:720rpx; 
  margin: 0 auto;
  border: 2rpx solid var(--light-blue-gray);
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, .5);
  box-shadow: 0 0 5rpx 0 rgba(131, 131, 131, 0.3);
}
 

.operation-panel {   
  height: 300rpx;
  display: flex; 
  flex-direction: column; 
  padding: 20rpx;
  background-color: var(--white);
}
 
.label {
  margin-right: 10rpx;
  font-size: 32rpx;
  white-space: nowrap;
}
.thickness {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}
.thickness-item {
  display: flex ;
  align-items: center;
  justify-content: flex-start;
  width: 55rpx;
  height: 55rpx;
  margin-left: 15rpx;
}
.xs,.s,.m,.l,.xl,.xxl,.xxxl,.xxxxl {
  
  border-radius: 50%;
}
.pen-border {
  border: 6rpx solid #fff;
  box-shadow: 0 0 5rpx #333;
  animation: jello .5s ease infinite;
}
 
.xs {
  width: 2rpx;
  height: 2rpx;
}
.s {
  width: 4rpx;
  height: 4rpx;
}
.m {
  width: 10rpx;
  height:  10rpx;
}
.l {
  width: 15rpx;
  height:15rpx;
}
.xl {
  width: 20rpx;
  height: 20rpx;
}
.xxl{
  width: 30rpx;
  height: 30rpx;
}
.xxxl{
  width: 40rpx;
  height: 40rpx;
}
.xxxxl{
  width: 50rpx;
  height: 50rpx;
}

.pen-color {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 680rpx; 
  overflow: hidden;
}
.color-list {
  width: 500rpx; 
}
.color-item {
  display: inline-block;
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
}
.select-color { 
  border: 4rpx solid #FFF;
}
.select-erase {
  background: rgba(255, 255, 255, .5);
  box-shadow: 0 0 3rpx 3rpx #333;
}
.prompt {
  width: 30rpx;
  font-size: 24rpx;
  color: red;
} 
  

.tool-btns{
  display: flex; 
  justify-content:space-around;
  margin-top: 20rpx;
}
.tool-button{
  width:180rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color:var(--page-pure-gary);
  border-radius: 40rpx;
  color:var(--soot-gary);
  font-size: 26rpx;
}
.tool-button .iconfont{
  margin-right: 10rpx;
}
.quite{
  background-color: #fceced;
}
.backup-up{
  background-color: #d8e3ff;
}

@import './draft-pad.wxss'; 