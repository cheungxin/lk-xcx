/*防止页面被滑动*/  
page{
  width: 100vw;
  min-height: 100vh;
  overflow: auto;
}
.page-container{ 
  padding-bottom: 80rpx; 
  background-color: var(--page-background-color);
}
.navigation-content{
  text-align: center;
}
/* 题目内容区域 */  

.topic-number {
  width: 240rpx;
  height: 60rpx;
  color: var(--soot-gray);
  font-size:42rpx; 
  display: flex;
  justify-content: flex-start;
  align-items: center;
}
.topic-type{
  font-size: 36rpx;
  color: var(--soot-gray);
}
.text-index {
  color: var(--color-primary);
  font-size:42rpx;
}

  

/*题目滚动区域*/
.topic-view {
  width: 750rpx;  
}   
.item-box{
  width: 720rpx; 
  min-height:300rpx;
  margin: 50rpx auto;  
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 20rpx;
  background-color:var(--white);
}
/*内容换行*/
.topic-item { 
  width: 680rpx;
  padding:40rpx 0rpx;
}
  
.topic-item-wrap{
  display: flex;  
  flex-wrap: wrap; 
  align-items:center;
  justify-content: center; 
}

.topic-content { 
  font-size: 60rpx;
  margin-right: 20rpx;
}

.topic-item-parting-line{
  width: 680rpx;
  margin: 40rpx auto;
  border: 1rpx dashed  var(--content-devider);   
}

.topic-item-answer{
  width: 660rpx;
  display: flex;
  justify-content: space-between;
  margin: 30rpx auto 0 auto; 
} 
.topic-answer-text{
  font-size: 38rpx;
}  
.topic-answer {   
   display: flex; 
   width:300rpx;  
   align-items: center;
}
.topic-answer-label{
  margin-right: 30rpx;
  color: var(--soot-gray);
} 
.is-wrong{
  color: var(--contrast-orange-color);
}
.is-right{
  color: var(--color-primary);
}
 
.topic-types{
  width: 100%;
  background-color:var(--white);
  padding: 30rpx 0;
  padding-left: 20rpx;
}
.topic-type-level-icon{
  color: var(--page-mid2-gary);
}
.topic-level{
  color: var(--soot-gray);
}

.topic-content-division{
  display: flex;
  flex-direction: column;
  align-items: center;
}
.topic-content-division,.topic-equal-sign,.multiplying-term{
  font-size: 60rpx;
}
.division-sign{
  width: 100%;
  height: 2rpx;
  background-color: black;
}
.topic-equal-sign{
   margin: 0 10rpx;
}
.auxiliary{
  margin-top: 50rpx;
}
.topic-answer-auxiliary{
  margin-right: 30rpx;
}

.special-fraction-input{
  margin-top: 20rpx;
  padding: 10rpx;
  border: 3rpx solid var(--soot-gray);
  border-radius: 10rpx;
}
 

@media screen and (min-device-width: 768px) { 
  .topic-types{
    font-size: 26px;
  }
  .page-container{ 
      padding-bottom:180px; 
  } 
  .topic-answer-label{
    font-size:30px;
  }
}
