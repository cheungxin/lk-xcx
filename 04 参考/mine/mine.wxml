    <!-- 底部设置 -->
    <view class="bottom-setting">
        <van-cell-group inset wx:if="{{false}}">
            <van-cell title="收货地址管理" size="large" icon="https://wqianc.com/static/member-index/zhanghao.png" is-link bind:tap="goAddress" />
            <!-- <van-cell title="开户行账号"  size="large" icon="https://wqianc.com/static/member-index/shezhe.png" is-link/> -->
            <van-cell title="课程优惠权益" size="large" icon="https://wqianc.com/static/member-index/gonggao.png" bind:tap="goCuorseBenefits">
                <van-icon slot="right-icon" name="arrow" class="custom-icon" color="#969799" wx:if="{{distributionRecords===0}}" />
                <van-icon slot="right-icon" name="arrow" class="custom-icon" color="#969799" info="{{distributionRecords}}" wx:else />
            </van-cell>
            <van-cell title="我的推广" size="large" icon="https://wqianc.com/static/member-index/kefu.png" is-link bind:tap="goPromotion" />
            <van-cell title="联系客服" size="large" icon="https://wqianc.com/static/member-index/kefu.png">
                <button slot="right-icon" open-type="contact" class="contact-service-btn">
                    <van-icon name="arrow" class="custom-icon" color="#969799" />
                </button>
            </van-cell>
            <van-cell title="意见反馈" size="large" icon="https://wqianc.com/static/member-index/yijian.png" is-link bind:tap="goFeedback" />
            <van-cell title="消息动态" size="large" icon="https://wqianc.com/static/member-index/my-message.png" is-link bind:tap="goMyMessage" />
            <van-cell title="退出登录" size="large" icon="https://wqianc.com/static/member-index/login.png" is-link bind:tap="logOut" />
        </van-cell-group>
        <!-- 导航栏 -->
        <block wx:for="{{bottomlist}}">
            <view class="list-item-setting" wx:key="{{item.id}}" bind:tap="goItem" data-id="{{item.id}}" data-pageurl="{{item.pageurl}}">
                <view class="left-box">
                    <image src="{{item.icon}}"></image>
                    <text class="setting-title-num">
                        <text class="setting-num" wx:if="{{item.isNum&&item.isNum>0}}">{{item.isNum}}</text>
                        <text class="setting-title">{{item.name}}</text>
                    </text>
                </view>
                <view class="right-icon">
                    <van-icon name="arrow" color="#AAAAAA" />
                </view>
            </view>
        </block> 
         <block>
            <button class="reset-button list-item-setting" open-type="contact" bindcontact="handleContact">
                <view class="left-box">
                    <image src="https://wqianc.com/static/member-index/kefu.png"></image>
                    <text class="setting-title">联系客服</text>
                </view>
                <view class="right-icon">
                    <van-icon name="arrow" color="#AAAAAA" />
                </view>
            </button>
        </block>
        <block>
            <view class="list-item-setting" wx:if="{{isLogin}}" bind:tap="logOut">
                <view class="left-box">
                    <image src="https://wqianc.com/static/member-index/login.png"></image>
                    <text class="setting-title">退出登录</text>
                </view>
                <view class="right-icon">
                    <van-icon name="arrow" color="#AAAAAA" />
                </view>
            </view>
        </block>
    </view>
</view> 