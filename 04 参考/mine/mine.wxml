<view class="container">
    <view class="uesr-info">
        <view class="info-left-box">
            <view class="left-image">
                <image src="{{userInfo.headImg}}" wx:if="{{userInfo.headImg}}"></image>
                <image wx:else src="https://wqianc.com/dashujiaoyu/upload/xcx/index/avatar.png" />
            </view>
            <view class="left-user-nickname-phone">
                <view class="left-nickname">
                    <text class="vip" wx:if="{{isLogin}}">{{userInfo.memberStar||0}}</text>
                    <text>{{userInfo.nickName||'微信昵称'}}</text>
                </view>
                <view class="left-phone" bind:tap="togglePhoneDisplay">
                    <text wx:if="{{showFullPhone}}">{{userInfo.phone||'******'}}</text>
                    <text wx:else>{{formattedPhone}}</text>
                </view>
            </view>
        </view>
        <view class="right-box">
            <view class="user-edit" bind:tap="goEditMy">
                <van-icon name="edit" />
                <text>编辑资料</text>
            </view>
        </view>
    </view>
    <!-- 登录卡片 -->
    <view class="login-member-message">
        <view class="top-point-login">
            <view class="left-masonry">
                <image src="https://wqianc.com/static/member-index/zhuanshi.png"></image>
                <view class="left-point" wx:if="{{isLogin}}">我的会员积分</view>
                <view class="left-point" wx:else>登录解锁更多功能</view>
            </view>
            <!-- 注册 -->
            <view class="point-num" bind:tap="goPoint" wx:if="{{isLogin}}">{{userInfo.points||0}}</view>
            <view class="login-register" wx:else bind:tap="goLogin">登录/注册</view>
        </view>
        <view class="member-interests">
            <view class="member-interests-item" bind:tap="goMemberquity">
                <view class="member-interests-item-left">
                    <image src="https://wqianc.com/static/member-index/member-interests.png"></image>
                    <text class="member-interests-item-title">会员权益</text>
                </view>
            </view>
            <view class="member-interests-item" bind:tap="goPoint">
                <view class="member-interests-item-left">
                    <image src="https://wqianc.com/static/member-index/Integral-detail.png"></image>
                    <text class="member-interests-item-title">积分明细</text>
                </view>
            </view>
            <view class="member-interests-item" bind:tap="getPoint">
                <view class="member-interests-item-left">
                    <image src="https://wqianc.com/static/member-index/getpoint.png"></image>
                    <text class="member-interests-item-title">获取积分</text>
                </view>
            </view>
        </view>
    </view>
    <!-- 我的订单 -->
    <view class="my-order">
        <view class="my-tab-change">
            <block wx:for="{{tablist}}" wx:key="{{item.id}}">
                <view class="my-tab-item {{item.id===chooseid?'my-tab-item-active':''}}" bind:tap="goChangeTab" data-id="{{item.id}}">
                    {{item.tabname}}
                </view>
            </block>
        </view>
        <view class="tab-line"></view>
        <block wx:if="{{chooseid===0}}">
            <view class="top-title-icon">
                <view class="left-my-order-title">
                    <view class="order-title-line"></view>
                    <view class="order-title-title">订单中心</view>
                </view>
                <view class="all-icon" bind:tap="goAllOrder">
                    <view class="all-title">全部</view>
                    <van-icon name="arrow" color="#999999" />
                </view>
            </view>
            <view class="order-status">
                <view class="order-status-item" bind:tap="goNoPay" data-index="{{0}}" wx:if="{{false}}">
                    <view class="top-icon">
                        <image src="https://wqianc.com/static/member-index/status-pay.png" />
                    </view>
                    <view class="bottom-title">
                        待付款
                    </view>
                </view>
                <view class="order-status-item" bind:tap="goNoPay" data-index="{{0}}">
                    <view class="top-icon">
                        <image src="https://wqianc.com/static/member-index/status-goods.png" mode="" />
                    </view>
                    <view class="bottom-title">
                        待收货
                    </view>
                </view>
                <view class="order-status-item" bind:tap="goNoPay" data-index="{{1}}">
                    <view class="top-icon">
                        <image src="https://wqianc.com/static/member-index/status-receive.png" mode="" />
                    </view>
                    <view class="bottom-title">
                        已完成
                    </view>
                </view>
                <view class="order-status-item" bind:tap="goNoPay" data-index="{{3}}">
                    <view class="top-icon">
                        <van-icon name="https://wqianc.com/static/member-index/cart.png" size="25px" wx:if="{{shopCartInfo===0}}" />
                        <van-icon name="https://wqianc.com/static/member-index/cart.png" size="25px" info="{{shopCartInfo}}" wx:else />
                    </view>
                    <view class="bottom-title">
                        购物车
                    </view>
                </view>
            </view>
        </block>
        <block wx:if="{{chooseid===1}}">
            <view class="top-title-icon">
                <view class="left-my-order-title">
                    <view class="order-title-line"></view>
                    <view class="order-title-title">学员中心</view>
                </view>
                <view class="all-icon" bind:tap="goStudentCenter" wx:if="{{secondStudentMenus.length===5}}">
                    <view class="all-title">全部</view>
                    <van-icon name="arrow" color="#999999" />
                </view>
            </view>
            <view class="my-student-center order-status">
                <view class="order-status-item" data-item="{{item}}" bind:tap="jumpToOtherMiniProgram"
                wx:for="{{secondStudentMenus}}" 
                wx:key="{{item.id}}"
                wx:if="{{item.isShow==='是'}}">
                    <view class="top-icon">
                        <image src="{{'https://qn.wqcheng.com/'+item.icon[0].qnKey}}"/>
                    </view>
                    <view class="bottom-title">
                        {{item.secondMenu}}
                    </view>
                </view>
            </view>
        </block>
        <block wx:if="{{chooseid===2}}">
            <view class="top-title-icon">
                <view class="left-my-order-title">
                    <view class="order-title-line"></view>
                    <view class="order-title-title">家长中心</view>
                </view>
                <!-- <view class="all-icon" bind:tap="goStudentCenter">
                    <view class="all-title">全部</view>
                    <van-icon name="arrow" color="#999999" />
                </view> -->
            </view>
            <view class="my-student-center order-status">
                <view class="order-status-item" data-index="{{1}}" bind:tap="goLookStudent"
                wx:if="{{false}}">
                    <view class="top-icon">
                        <image src="https://wqianc.com/static/member-index/dopractice.png" />
                    </view>
                    <view class="bottom-title">
                        学员成绩
                    </view>
                </view>
                <view class="order-status-item" data-index="{{2}}" bind:tap="goLookStudent">
                    <view class="top-icon">
                        <image src="https://wqianc.com/static/member-index/kaoqing.png" />
                    </view>
                    <view class="bottom-title">
                        学员考勤
                    </view>
                </view>
                <view class="order-status-item"  data-index="{{3}}" bind:tap="goLookStudent"
                >
                    <view class="top-icon">
                        <image src="https://wqianc.com/static/member-index/dopractice.png" />
                    </view>
                    <view class="bottom-title">
                        家校中心
                    </view>
                </view>
            </view>
        </block>
    </view>
