page {
    background-color: #f7f7fa;
}

/* 去除button默认样式 */
button.reset-button::after {
	border: none;
}

button.reset-button {
	min-width:0 !important;
	text-align: initial;
	background-color: transparent;
	margin: initial !important;
	padding : 0; 
	line-height: inherit;
	border-radius: 0;
	font:initial;
}

.container{
    padding-bottom: 40rpx;
}
.uesr-info {
    width: 686rpx;
    margin: 0 auto;
    margin-top: 166rpx;
    box-sizing: border-box;
    padding: 20rpx;
}

.uesr-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.info-left-box {
    display: flex;
}

.left-image {
    width: 120rpx;
    height: 120rpx;
}

.left-image image {
    width: 100%;
    height: 100%;
    border-radius: 50%;
}

.left-user-nickname-phone {
    margin-left: 10rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
}

.left-nickname {
    display: flex;
    color: rgba(51, 51, 51, 1);
    font-size: 36rpx;
    font-weight: 700;
    position: relative;
    width: fit-content
}

.vip {
    position: absolute;
    right: -105rpx;
    top: 0;
    width: 100rpx;
    height: 32rpx;
    opacity: 1;
    border-radius: 46rpx;
    background: linear-gradient(90deg, #FFDB70 0%, #FC861E 100%);
    font-size: 22rpx;
    color: #ffffff;
    text-align: center;
    line-height: 32rpx;
}

/* 联系客服按钮样式 */
.contact-service-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #323233;
}

.contact-service-btn::after {
  border: none;
}

/* 增加van-cell组件的行高 */
 

.left-phone {
    color: rgba(51, 51, 51, 1);
    font-size: 24rpx;
    font-weight: 400;
    cursor: pointer;
    padding: 8rpx 0;
    border-radius: 8rpx;
    transition: background-color 0.2s;
}

.left-phone:active {
    background-color: rgba(0, 0, 0, 0.05);
}

.right-box {
    color: #373948;
    font-size: 24rpx;
    font-weight: 500;
}

/* 
** 登录卡片
*/
.login-member-message {
    width: 686rpx;
    box-sizing: border-box;
    margin: 0 auto;
    padding: 20rpx;
    background-color: #ffffff;
    border-radius: 20rpx;
    background-position: top center;
    background-image: url('https://wqianc.com/static/member-index/my-message-vip.png');
    background-size: 686rpx 150rpx;
    background-repeat: no-repeat;
}

.top-point-login {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.left-masonry {
    display: flex;
}

.left-masonry image {
    width: 40rpx;
    height: 40rpx;
}

.left-point {
    margin-left: 10rpx;
    font-size: 32rpx;
    color: #FFDBB5;
    font-weight: 400;
}

.point-num {
    width: 200rpx;
    font-size: 48rpx;
    color: #FFDBB5;
    font-weight: 400;
}

.login-register {
    width: 172rpx;
    height: 56rpx;
    color: #333333;
    border-radius: 40rpx;
    font-size: 24rpx;
    text-align: center;
    line-height: 56rpx;
    background: linear-gradient(90deg, rgba(255, 234, 203, 1) 0%, rgba(232, 188, 119, 1) 100%);
}

/* 
** 会员权益
*/
.member-interests { 
    display: flex;
    justify-content: space-around;
    height: 100rpx;
    padding-top: 30rpx;
}
.member-interests-item{
    height: 130rpx;
    display: flex;
    align-items: center;
}
.member-interests-item-left {
    display: flex;
    align-items: center;
}

.member-interests-item-left image {
    width: 32rpx;
    height: 32rpx;
}

.member-interests-item-title {
    margin-left: 10rpx;
    color: #333333;
    font-size: 28rpx;
    font-weight: 500;
}

/* 
** 我的订单
*/

.my-order {
    width: 686rpx;
    margin: 0 auto;
    margin-top: 40rpx;
    background: #ffffff;
    border-radius: 20rpx;
    box-sizing: border-box;
    padding: 20rpx;
}
.my-tab-change{
    display: flex;
    justify-content: space-between;
    padding: 0 40rpx;
}
.my-tab-item{
    width: 176rpx;
    height: 64rpx;
    border-radius: 50rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 28rpx;
    font-weight: 400;
    color:#323233;
}
.my-tab-item-active{
    background-color: #43CF7C;
    color: #ffffff;
}
.tab-line{
    height: 1rpx;
    background-color: #F7F7F7;
    margin:30rpx 0;
}
.top-title-icon {
    display: flex;
    justify-content: space-between;
}

.left-my-order-title {
    display: flex;
    align-items: center;
}

.order-title-title {
    margin-left: 10rpx;
    font-size: 34rpx;
    font-weight: 400;
    color: #000000;
}

.all-icon {
    display: flex;
    align-items: center;
}

.all-title {
    color: #999999;
    font-size: 26rpx;
    font-weight: 500;
}

.order-title-line {
    width: 8rpx;
    height: 32rpx;
    background-color: #43CF7C;
    border-radius: 40rpx;
}

.order-status-item {
    width: 160rpx;
    padding: 20rpx 0;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.order-status { 
    margin-top: 20rpx;
    display: flex;
}

.bottom-title {
    font-size: 28rpx;
    color: #1A1A1A;
    font-weight: 500;
}

.bottom-setting {
    margin-top: 40rpx;
   padding-bottom: 40rpx;
}

.order-status-item .top-icon image {
    width: 60rpx;
    height: 60rpx;
}

.bottom-setting{
    width: 686rpx;
    margin: 0 auto;
    margin-top: 40rpx;
    background: #ffffff;
    border-radius: 20rpx;
    box-sizing: border-box;
    padding: 20rpx;
}
.list-item-setting{
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80rpx;
    border-bottom: 1rpx solid #f7f7fa;
}
.left-box{
    display: flex;
    align-items: center;
}
.left-box image{
    width: 48rpx;
    height: 48rpx;
}
.left-box .setting-title{
    font-size: 28rpx;
    font-weight: 500;
    color: #000000;
}
.setting-title-num{
    position: relative;
}
.setting-num{
    position: absolute;
    right: -50rpx;
    width: 32rpx;
    height: 32rpx;
    border-radius: 50%;
    background-color: #EE0A24;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #ffffff;
    font-size: 24rpx;
}