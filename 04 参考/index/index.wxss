.navigation-wrap{
  width:720rpx;
  /* height:340rpx; 不需要固定高度，由内容撑开 */
  margin: -70rpx auto 50rpx; 
  /* 移除白色背景和圆角，由内部元素控制 */
  background-color: transparent; 
  border-radius: 0;
}

/*navbar*/
.navbar {
	width: 720rpx;  
}

.navbar-top{
  width: 720rpx;
  height: 100rpx; /* 稍微增加高度以容纳圆角设计 */
  /* 移除白色背景 */
  background-color: transparent; 
  display: flex;
  justify-content: center;
  align-items: flex-end; /* 底部对齐，确保Tab贴合下方卡片 */
  opacity: 0;
  animation: fadeIn 0.3s ease forwards;
  /* 为下方的反向圆角留出空间，不需要圆角 */
  border-radius: 0;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.plate-btn{
  flex: 1;
  height: 90rpx; /* Tab高度 */
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative; /* 用于定位伪元素 */
  z-index: 1;
  background-color:#f7f8fa;
  border-radius: var(--tab-radius) var(--tab-radius) 0 0;
  transition: all 0.3s;
  cursor: pointer;
}

/* 激活状态的 Tab */
.plate-btn.active {
  background-color: #fff;
  z-index: 2; /* 确保在最上层 */
}

/* 左侧反向圆角 (凹陷效果) */
.plate-btn.active::before {
  content: "";
  position: absolute;
  bottom: 0;
  left: calc(var(--tab-radius) * -1); /* 向左偏移一个半径 */
  width: var(--tab-radius);
  height: var(--tab-radius);
  /* 径向渐变实现凹陷：左下角是填充色(#fff)，右上角是透明 */
  /* 注意：这里的逻辑是填补 Tab 和 Card 之间的空隙 */
  /* 实际上我们需要一个位于左下角的白色块，但其右上角被挖空 */
  /* 使用 radial-gradient(circle at 0 0, transparent radius, #fff ...) */
  /* circle at 0 0 (Top Left) -> transparent -> white */
  background: radial-gradient(circle at 0 0, transparent var(--tab-radius), #fff calc(var(--tab-radius) + 0.5px));
}

/* 右侧反向圆角 (凹陷效果) */
.plate-btn.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  right: calc(var(--tab-radius) * -1); /* 向右偏移一个半径 */
  width: var(--tab-radius);
  height: var(--tab-radius);
  /* circle at 100% 0 (Top Right) -> transparent -> white */
  background: radial-gradient(circle at 100% 0, transparent var(--tab-radius), #fff calc(var(--tab-radius) + 0.5px));
}

.plate-btn-line{
  width: 32rpx; /* 稍微加宽一点 */
  height: 6rpx;
  margin-top: 8rpx;
  border-radius: 4rpx; 
  background-color: transparent;
  transition: background-color 0.3s;
}

/* 激活状态下的横线 */
.plate-btn.active .plate-btn-line{
  background-color: var(--color-primary);
}

.plate-btn-wrap{
  width: auto;
  min-width: 80rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.plate-btn-txt{
  font-size: 32rpx; /* 调整字体大小 */ 
  color: var(--soot-gray);
  transition: all 0.3s;
}

/* 激活状态下的文字 */
.plate-btn.active .plate-btn-txt{
  font-size: 36rpx;
  font-weight: 800;
  color: var(--soot-gray); /* 或者使用 var(--color-primary) 如果想跟设计稿一致，设计稿是黑色 */
}

.nav-swiper {
	width: 720rpx;
	margin: 0 auto; 
	height: 240rpx; /* 增加高度 */
  padding-top: 20rpx;
  background-color: #fff; /* 卡片背景色 */
  border-radius: var(--tab-radius) var(--tab-radius) 0 0; /* 上圆下直，衔接下方dots */
  /* 关键：如果 Tab 在左边，左上角不需要圆角？不，Tab 盖在上面即可 */
  /* 为了让 Tab 的反向圆角生效，Card 需要有背景色且 Tab 盖住它 */
  /* 由于 Tab 是 z-index: 2，Card 是默认，Tab 会盖住 Card 的顶部边框 */
  /* 为了完美衔接，Card 的圆角应该保留，Tab 的白色背景会与 Card 融合 */ 
  position: relative;
  z-index: 1; /* 确保低于 Tab (z-index:2) 但高于其他背景 */ 
  margin-top: -1rpx; /* 稍微上移，防止缝隙 */
}

.nav-swiper-item {
	width: 720rpx;
	display: block;
	display: flex;  
	justify-content: center;
  align-items: center;
}

.nav-item {
	display: inline-block;
	width: 180rpx;
	height: 180rpx;
}

.nav-item .nav-btn {
	text-align: center;
	font-size: 26rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.nav-item .nav-btn image {
	width: 100rpx; /* 稍微调小图标 */
	height: 100rpx;
    margin-bottom: 10rpx;
}

.nav-item .nav-btn text {
	display: block;
	color: var(--soot-gray);
    font-size: 26rpx;
}

/*焦点/指示点*/
.dots {
  display: flex;
  justify-content: center;
  padding-bottom: 20rpx; /* 增加底部间距 */
  background: #fff; /* 确保背景一致 */
  border-bottom-left-radius: var(--tab-radius);
  border-bottom-right-radius: var(--tab-radius);
}

.dots-wrap {
  display: flex;
  justify-content: space-between;
  border-radius: 8rpx; 
  background: var(--light-gray); 
}

.dots .dot {
  width: 30rpx;
  height: 8rpx; 
}

/* 定义动画 */
@keyframes width-grow {
  from {
      width: 1rpx; /* 动画开始时的宽度 */
  }
  to {
      width: 30rpx; /* 动画结束时的宽度 */
  }
}

 .dot-active {
   height: 100%; 
   border-radius: 8rpx; 
  /* 初始宽度由动画控制，所以这里不需要设置 */
  background: var(--color-primary);
  animation: width-grow 3s ease-in-out forwards; /* 应用动画 */
}

