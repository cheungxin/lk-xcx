/**
 * 登录页面样式 - 微信手机号授权登录
 */

/* 页面容器 */
.page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #1677ff 0%, #f5f5f5 500rpx);
}

/* 内容容器 */
.login-container {
  padding: 32rpx;
  padding-bottom: 64rpx;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 64rpx);
}

/* ==================== Logo 区域 ==================== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 80rpx;
}

.logo-icon {
  font-size: 160rpx;
  margin-bottom: 32rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

.logo-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.logo-subtitle {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 登录说明 ==================== */
.login-desc {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* ==================== 授权区域 ==================== */
.auth-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.auth-button {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 48rpx;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
  padding: 0;
  margin: 0;
  line-height: 96rpx;
}

.auth-button::after {
  border: none;
}

.auth-button:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
}

.auth-button[disabled] {
  opacity: 0.7;
  background: linear-gradient(135deg, #999 0%, #666 100%);
}

.auth-button-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.auth-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 微信登录 */
.wechat-login {
  margin-top: 32rpx;
  padding: 16rpx 32rpx;
}

.wechat-text {
  font-size: 28rpx;
  color: #07c160;
  text-decoration: underline;
}

/* ==================== 用户协议 ==================== */
.agreement-section {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 40rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
}

.agreement-link {
  font-size: 24rpx;
  color: #1677ff;
  margin: 0 4rpx;
}

/* ==================== 提示区域 ==================== */
.tips-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

