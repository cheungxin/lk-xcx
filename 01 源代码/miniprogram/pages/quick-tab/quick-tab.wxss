/* 快练Tab页样式 */

.page {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
}

.page-aura {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  pointer-events: none;
  z-index: 0;
}

.page-aura--top {
  background: linear-gradient(180deg, #FFF7E6 0%, #F5F7FA 100%);
}

.page-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
  box-sizing: border-box;
}

.page-header {
  padding: 32rpx 32rpx 24rpx;
}

.page-header__title {
  display: flex;
  align-items: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.page-header__icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.page-header__desc {
  font-size: 26rpx;
  color: #7F8C8D;
  margin-left: 48rpx;
}

/* 题数选择 */
.count-section {
  margin: 0 32rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.count-section__label {
  font-size: 26rpx;
  color: #5C6475;
  flex-shrink: 0;
}

.count-list {
  display: flex;
  gap: 12rpx;
}

.count-pill {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #5C6475;
  background: #FFFFFF;
  border: 2rpx solid #E8ECF4;
  transition: all 0.2s;
}

.count-pill--active {
  background: #1664FF;
  color: #FFFFFF;
  border-color: #1664FF;
}

/* 开始卡片 */
.start-card {
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.start-card__bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  z-index: 0;
}

.start-card__content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.start-card__icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.start-card__info {
  flex: 1;
}

.start-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 4rpx;
}

.start-card__desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 分区 */
.section {
  margin: 0 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
}

/* 科目网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  background: #FAFBFD;
  transition: background 0.2s;
}

.category-card:active {
  background: #EEF2FF;
}

.category-card__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-card__name {
  font-size: 24rpx;
  font-weight: 500;
  color: #1A1A2E;
  margin-bottom: 4rpx;
}

.category-card__count {
  font-size: 20rpx;
  color: #9AA3B2;
}

/* 最近练习 */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #FAFBFD;
}

.recent-item__info {
  flex: 1;
}

.recent-item__title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A2E;
  display: block;
  margin-bottom: 4rpx;
}

.recent-item__meta {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #9AA3B2;
}

.recent-item__dot {
  margin: 0 8rpx;
  color: #D8DCE6;
}

.recent-item__accuracy {
  font-size: 28rpx;
  font-weight: 600;
}

/* 提示 */
.tip-card {
  margin: 0 32rpx 32rpx;
  padding: 20rpx 24rpx;
  background: #FFF7E6;
  border-radius: 16rpx;
  display: flex;
  align-items: flex-start;
}

.tip-card__text {
  font-size: 22rpx;
  color: #ED7B2F;
  margin-left: 12rpx;
  line-height: 1.5;
}
