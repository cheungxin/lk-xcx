/* 设置页 */
.settings-page {
  min-height: 100vh;
  background: #f7f8fa;
}

.settings-content {
  padding: 0 0 32rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
}

.section-header__accent {
  width: 6rpx;
  height: 28rpx;
  background: #1664ff;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.section-header__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d2129;
}

.card {
  margin: 0 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.cell-note {
  font-size: 28rpx;
  color: #86909c;
}

/* 用户信息卡片 */
.user-info-card {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: #f2f3f5;
}

.user-info-detail {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d2129;
  display: block;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: #86909c;
}

/* 退出登录 */
.logout-section {
  padding: 48rpx 32rpx;
}

/* 底部留白 */
.bottom-spacer {
  height: 60rpx;
}

/* 字体大小选择弹窗 */
.font-picker {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.font-picker__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.font-picker__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d2129;
}

.font-picker__options {
  display: flex;
  gap: 24rpx;
}

.font-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
  position: relative;
}

.font-option--active {
  background: #e8f3ff;
  border: 2rpx solid #1664ff;
}

.font-option__text {
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 12rpx;
}

.font-option__label {
  font-size: 26rpx;
  color: #4e5969;
}

/* 确认弹窗 */
.confirm-dialog {
  width: 560rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.confirm-dialog__title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d2129;
  margin-bottom: 16rpx;
}

.confirm-dialog__desc {
  font-size: 28rpx;
  color: #86909c;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 36rpx;
}

.confirm-dialog__btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
}
