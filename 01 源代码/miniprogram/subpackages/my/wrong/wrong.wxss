.page-container {
  min-height: 100vh;
  background: #F3F7FD;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* 导航栏右侧 */
.nav-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.nav-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
}

/* 标签页容器 */
.tabs-container {
  background: #FFFFFF;
  padding: 0 24rpx;
}

/* TDesign Tabs 样式覆盖 */
.tabs-container t-tabs {
  --td-tab-nav-bg-color: #FFFFFF;
  --td-tab-item-color: #72809A;
  --td-tab-item-active-color: #4B74FF;
  --td-tab-track-color: #4B74FF;
  --td-tab-border-color: #EEF2F8;
  --td-tab-item-font-size: 32rpx;
  --td-tab-item-active-font-weight: 600;
}

/* 筛选器容器 */
.filter-container {
  background: #FFFFFF;
  border-bottom: 1rpx solid #EEF2F8;
}

/* TDesign DropdownMenu 样式覆盖 */
.filter-container t-dropdown-menu {
  --td-dropdown-menu-bg-color: #FFFFFF;
  --td-dropdown-menu-item-color: #2F3442;
  --td-dropdown-menu-item-active-color: #4B74FF;
  --td-dropdown-menu-item-disabled-color: #C9CDD4;
}

/* 内容区域 */
.content-container {
  padding: 24rpx;
}

.tab-content {
  min-height: 60vh;
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(42, 77, 145, 0.04);
  border: 1rpx solid rgba(238, 242, 248, 0.8);
  transition: all 0.3s ease;
}

.category-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(42, 77, 145, 0.06);
}

.category-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
}

.category-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.category-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #4B74FF;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.category-icon.expanded {
  background: #FF6B6B;
}

.category-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #2F3442;
}

.category-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-count {
  font-size: 28rpx;
  color: #72809A;
  min-width: 40rpx;
  text-align: right;
}

.category-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-edit {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #EEF3FF;
  transition: all 0.2s ease;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.category-edit:active {
  background: #D3E3FD;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  border-radius: 50%;
  background: #F5F8FF;
}

.empty-text {
  font-size: 28rpx;
  color: #95A0B3;
}
