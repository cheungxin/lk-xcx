page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.result-page {
  flex: 1;
  height: 100%;
  width: 100%;
  background: #f5f7fb;
  display: flex;
  flex-direction: column;
}

.result-scroll {
  flex: 1;
  height: 100%;
  width: 100%;
}

.result-content {
  padding: 24rpx 24rpx 200rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.overview-card,
.question-card,
.answer-card,
.score-card {
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 38rpx rgba(20, 56, 110, 0.06);
}

.overview-card__title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #243042;
}

.overview-card__subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #97a3b5;
}

.overview-pill-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.overview-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f4f7fb;
  font-size: 24rpx;
  color: #5f6b7f;
}

.question-tabs {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.question-tab {
  min-width: 136rpx;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(20, 56, 110, 0.05);
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #5f6b7f;
}

.question-tab--active {
  background: linear-gradient(135deg, #1664ff 0%, #4f8dff 100%);
  color: #ffffff;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-head__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #243042;
}

.question-card__meta {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.question-card__title {
  display: block;
  margin-top: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #243042;
}

.question-card__text,
.answer-card__text {
  display: block;
  margin-top: 16rpx;
  white-space: pre-wrap;
  font-size: 28rpx;
  line-height: 1.8;
  color: #354154;
}

.answer-card__text--self {
  color: #4d5a70;
}

.answer-card__count {
  font-size: 26rpx;
  font-weight: 600;
  color: #1664ff;
}

.score-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.score-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.score-item__dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-top: 16rpx;
  background: #1664ff;
  flex-shrink: 0;
}

.score-item__text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.7;
  color: #354154;
}

.empty-state {
  flex: 1;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-state__title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #243042;
}

.empty-state__desc {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #8d99ac;
}

.result-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 18rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 36rpx rgba(19, 40, 72, 0.08);
}

.result-footer > t-button {
  flex: 1;
}
