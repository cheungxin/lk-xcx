page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.quick-page {
  flex: 1;
  height: 100%;
  width: 100%;
  background: #f7f8fa;
}

/* ============ 配置面板 ============ */
.config-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 48rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7f8fa 100%);
}

.config-hero__icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #FFF8E6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.config-hero__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d2129;
  margin-bottom: 12rpx;
}

.config-hero__desc {
  font-size: 28rpx;
  color: #86909c;
}

.config-section {
  margin: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.config-section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 24rpx;
  display: block;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-tag {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  background: #f2f3f5;
  font-size: 28rpx;
  color: #4e5969;
  transition: all 0.2s;
}

.category-tag--active {
  background: #1664ff;
  color: #ffffff;
}

.count-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  padding: 16rpx 0;
}

.count-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f2f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-btn--disabled {
  opacity: 0.4;
}

.count-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1664ff;
  min-width: 120rpx;
  text-align: center;
}

.count-presets {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  justify-content: center;
}

.count-preset {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  background: #f2f3f5;
  font-size: 26rpx;
  color: #4e5969;
}

.count-preset--active {
  background: #e8f3ff;
  color: #1664ff;
  font-weight: 600;
}

.start-btn-wrap {
  padding: 48rpx 32rpx;
}

/* ============ 答题界面 ============ */
.practice-view {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.practice-top-bar {
  background: #ffffff;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e5e6eb;
}

.timer-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.timer-text {
  font-size: 28rpx;
  color: #4e5969;
  font-weight: 500;
}

.progress-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #1664ff;
  font-weight: 600;
}

.progress-bar-wrap {
  height: 6rpx;
  background: #e5e6eb;
}

.progress-bar {
  height: 100%;
  background: #1664ff;
  transition: width 0.3s;
}

.question-scroll {
  flex: 1;
  height: 100%;
  width: 100%;
}

.question-container {
  padding: 32rpx;
  padding-bottom: 200rpx;
}

.question-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.question-stem {
  font-size: 32rpx;
  color: #1d2129;
  font-weight: 500;
  line-height: 1.7;
  display: block;
  margin-bottom: 40rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
}

.option-item--correct {
  background: #e8f3ed;
  border-color: #00a870;
}

.option-item--wrong {
  background: #fcefee;
  border-color: #e34d59;
}

.option-letter {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f2f3f5;
  color: #4e5969;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-letter--correct {
  background: #00a870;
  color: #ffffff;
}

.option-letter--wrong {
  background: #e34d59;
  color: #ffffff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #1d2129;
  line-height: 1.5;
}

.option-icon {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.analysis-box {
  margin-top: 40rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.analysis-box__header {
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1664ff;
}

.analysis-box__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
}

.analysis-box__content {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.analysis-box__answer {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.analysis-box__label {
  font-size: 26rpx;
  color: #86909c;
}

.analysis-box__val {
  font-size: 30rpx;
  font-weight: 700;
}

.analysis-box__val--correct {
  color: #00a870;
}

.analysis-box__text {
  font-size: 28rpx;
  color: #4e5969;
  line-height: 1.7;
}

/* ============ 底部操作栏 ============ */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 22rpx;
  color: #4e5969;
}

.bottom-action--primary {
  flex: 1;
}

/* ============ 结果面板 ============ */
.result-scroll {
  height: calc(100vh - 88px);
}

.result-container {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.result-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-card__circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.result-card__circle--good {
  background: linear-gradient(135deg, #e8f3ed 0%, #d4f0e0 100%);
}

.result-card__circle--bad {
  background: linear-gradient(135deg, #fcefee 0%, #f8d7da 100%);
}

.result-card__accuracy {
  font-size: 56rpx;
  font-weight: 800;
  color: #1d2129;
}

.result-card__label {
  font-size: 24rpx;
  color: #86909c;
  margin-top: 4rpx;
}

.result-card__stats {
  display: flex;
  align-items: center;
  width: 100%;
  justify-content: space-around;
}

.result-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-stat__val {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d2129;
}

.result-stat__val--correct {
  color: #00a870;
}

.result-stat__val--wrong {
  color: #e34d59;
}

.result-stat__val--total {
  color: #1664ff;
}

.result-stat__label {
  font-size: 24rpx;
  color: #86909c;
  margin-top: 4rpx;
}

.result-stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e5e6eb;
}

/* 分科统计 */
.breakdown-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-top: 24rpx;
}

.breakdown-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 24rpx;
  display: block;
}

.breakdown-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.breakdown-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.breakdown-item__name {
  font-size: 28rpx;
  color: #4e5969;
  width: 120rpx;
  flex-shrink: 0;
}

.breakdown-item__bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #f2f3f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.breakdown-item__bar {
  height: 100%;
  background: #1664ff;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.breakdown-item__text {
  font-size: 26rpx;
  color: #86909c;
  width: 80rpx;
  text-align: right;
  flex-shrink: 0;
}

.result-actions {
  margin-top: 48rpx;
}

/* ============ 答题卡弹窗 ============ */
.answer-card-popup {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.answer-card-popup__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.answer-card-popup__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d2129;
}

.answer-card-popup__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ac-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  background: #f2f3f5;
  color: #86909c;
}

.ac-item--current {
  background: #e8f3ff;
  color: #1664ff;
  border: 2rpx solid #1664ff;
}

.ac-item--correct {
  background: #e8f3ed;
  color: #00a870;
}

.ac-item--wrong {
  background: #fcefee;
  color: #e34d59;
}

.ac-item--pending {
  background: #f2f3f5;
  color: #c9cdd4;
}

.answer-card-popup__legend {
  display: flex;
  gap: 32rpx;
  margin-top: 32rpx;
  justify-content: center;
}

.ac-legend {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #86909c;
}

.ac-legend__dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.ac-legend__dot--correct {
  background: #e8f3ed;
}

.ac-legend__dot--wrong {
  background: #fcefee;
}

.ac-legend__dot--current {
  background: #e8f3ff;
  border: 1rpx solid #1664ff;
}

.ac-legend__dot--pending {
  background: #f2f3f5;
}
