page {
  height: 100%;
  background: #f4f7fc;
}

.detail-page {
  min-height: 100vh;
  background: #f4f7fc;
}

.detail-scroll {
  height: calc(100vh - 88px);
}

.detail-content {
  padding: 24rpx;
}

.detail-hero {
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f6f9ff 100%);
  box-shadow: 0 18rpx 42rpx rgba(23, 52, 103, 0.06);
}

.detail-hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-hero__title {
  display: block;
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.65;
  color: #1f2329;
}

.detail-hero__facts {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-fact {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef3fb;
  max-width: 100%;
}

.detail-fact__label {
  font-size: 20rpx;
  color: #7d8ba0;
}

.detail-fact__value {
  font-size: 22rpx;
  font-weight: 600;
  color: #334155;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-hero__image {
  width: 100%;
  margin-top: 18rpx;
  border-radius: 22rpx;
}

.detail-hero__stats {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.detail-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #eef3fb;
  font-size: 22rpx;
  color: #6b7a90;
}

.detail-chip--danger {
  background: rgba(227, 77, 89, 0.1);
  color: #e34d59;
}

.detail-material {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 38rpx rgba(20, 56, 110, 0.06);
}

.detail-material__label {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #2f63ff;
}

.detail-material__preview {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-material__text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.75;
  color: #65758c;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.detail-material__image-box {
  width: 124rpx;
  height: 92rpx;
  border-radius: 18rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.detail-material__image {
  width: 100%;
  height: 100%;
}

.detail-card {
  margin-top: 20rpx;
  padding: 28rpx 26rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 38rpx rgba(20, 56, 110, 0.06);
}

.detail-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #23324a;
}

.detail-options {
  margin-top: 20rpx;
}

.detail-option {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: #f7f9fd;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.detail-option + .detail-option {
  margin-top: 14rpx;
}

.detail-option--selected {
  background: #edf4ff;
}

.detail-option--correct {
  background: rgba(0, 168, 112, 0.1);
}

.detail-option--wrong {
  background: rgba(227, 77, 89, 0.1);
}

.detail-option__letter {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #607189;
  flex-shrink: 0;
}

.detail-option__letter--selected {
  background: #2f63ff;
  color: #ffffff;
}

.detail-option__letter--correct {
  background: #00a870;
  color: #ffffff;
}

.detail-option__letter--wrong {
  background: #e34d59;
  color: #ffffff;
}

.detail-option__body {
  flex: 1;
  min-width: 0;
}

.detail-option__text {
  font-size: 28rpx;
  line-height: 1.65;
  color: #2f3442;
}

.detail-option__image {
  width: 100%;
  border-radius: 18rpx;
}

.detail-option__image--with-text {
  margin-top: 12rpx;
}

.detail-answer-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.detail-answer {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: #f7f9fd;
}

.detail-answer__label {
  display: block;
  font-size: 22rpx;
  color: #7d8ba0;
}

.detail-answer__value {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
}

.detail-answer__value--correct {
  color: #00a870;
}

.detail-answer__value--wrong {
  color: #e34d59;
}

.detail-answer__value--muted {
  color: #8d99ac;
}

.detail-knowledge {
  margin-top: 18rpx;
  display: inline-flex;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5f6f86;
  word-break: break-word;
}

.detail-explanation {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e7edf7;
}

.detail-explanation__title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #23324a;
}

.detail-explanation__content {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.85;
  color: #5f6f86;
}

.detail-empty {
  min-height: calc(100vh - 88px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.detail-empty__title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #334155;
}

.material-popup {
  height: 80vh;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

.material-popup__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 32rpx 18rpx;
}

.material-popup__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.material-popup__content {
  flex: 1;
}

.material-popup__body {
  padding: 0 32rpx 40rpx;
}

.material-popup__image {
  width: 100%;
  border-radius: 24rpx;
}

.material-popup__text {
  display: block;
  font-size: 28rpx;
  line-height: 1.9;
  color: #46556a;
  white-space: pre-wrap;
}
