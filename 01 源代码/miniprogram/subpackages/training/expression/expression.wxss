.expression-page {
  min-height: 100vh;
  background: #f5f7fb;
}

.expression-scroll {
  height: calc(100vh - 88rpx);
}

.expression-content {
  padding: 24rpx;
}

.search-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 38rpx rgba(20, 56, 110, 0.06);
}

.search-card__input {
  flex: 1;
  font-size: 28rpx;
  color: #243042;
}

.search-card__placeholder {
  color: #a0adbf;
}

.type-scroll {
  margin: 24rpx 0;
  white-space: nowrap;
}

.type-list {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 24rpx;
}

.type-pill {
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  color: #667388;
  box-shadow: 0 8rpx 24rpx rgba(20, 56, 110, 0.05);
}

.type-pill--active {
  background: linear-gradient(135deg, #1664ff 0%, #4f8dff 100%);
  color: #ffffff;
}

.group-card {
  margin-bottom: 24rpx;
}

.group-card__title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #243042;
}

.expression-card {
  margin-bottom: 18rpx;
  padding: 28rpx 26rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 38rpx rgba(20, 56, 110, 0.06);
}

.expression-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.expression-card__main {
  flex: 1;
}

.expression-card__title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #243042;
}

.expression-card__tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.expression-card__body {
  margin-top: 22rpx;
}

.expression-card__content,
.example-box__content {
  display: block;
  white-space: pre-wrap;
  font-size: 28rpx;
  line-height: 1.8;
  color: #354154;
}

.example-box {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.example-box__label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: #97a3b5;
}

.copy-link {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1664ff;
}

.empty-state {
  padding: 80rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.empty-state__text {
  font-size: 26rpx;
  color: #97a3b5;
}
