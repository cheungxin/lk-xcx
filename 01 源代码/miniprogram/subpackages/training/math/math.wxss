page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.math-page {
  flex: 1;
  height: 100%;
  width: 100%;
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
}

.math-top-bar {
  background: #ffffff;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #e5e6eb;
}

.timer-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.timer-text {
  font-size: 28rpx;
  color: #4e5969;
  font-weight: 500;
}

.progress-text {
  font-size: 28rpx;
  color: #1664ff;
  font-weight: 600;
  flex: 1;
  text-align: center;
}

.tool-btns {
  display: flex;
  gap: 20rpx;
}

.tool-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #1664ff;
  padding: 6rpx 12rpx;
  background: #EEF3FF;
  border-radius: 8rpx;
}

.math-scroll {
  flex: 1;
  height: 100%;
  width: 100%;
}

.math-container {
  padding: 32rpx;
  padding-bottom: 180rpx;
}

.math-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.math-num {
  font-size: 26rpx;
  color: #86909c;
}

.table-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #EEF3FF;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #1664ff;
}

.table-hint__text {
  font-size: 26rpx;
  color: #1664ff;
}

.math-stem {
  font-size: 32rpx;
  color: #1d2129;
  font-weight: 500;
  line-height: 1.8;
  display: block;
  margin-bottom: 32rpx;
  white-space: pre-wrap;
}

.formula-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #FFF8E6;
  border-radius: 8rpx;
  margin-bottom: 32rpx;
}

.formula-hint__text {
  font-size: 26rpx;
  color: #B97A40;
}

.math-options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.math-option {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
}

.math-option--correct {
  background: #e8f3ed;
  border-color: #00a870;
}

.math-option--wrong {
  background: #fcefee;
  border-color: #e34d59;
}

.math-option__letter {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f2f3f5;
  color: #4e5969;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.math-option__letter--correct {
  background: #00a870;
  color: #ffffff;
}

.math-option__letter--wrong {
  background: #e34d59;
  color: #ffffff;
}

.math-option__text {
  flex: 1;
  font-size: 30rpx;
  color: #1d2129;
}

.math-option__icon {
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 解析 */
.math-analysis {
  margin-top: 40rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.math-analysis__header {
  padding-left: 16rpx;
  border-left: 6rpx solid #1664ff;
  margin-bottom: 20rpx;
}

.math-analysis__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
}

.math-analysis__body {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.math-analysis__text {
  font-size: 28rpx;
  color: #4e5969;
  line-height: 1.8;
}

/* 底部操作栏 */
.math-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.math-bottom t-button {
  flex: 1;
}

/* ============ 公式弹窗 ============ */
.formula-popup {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.formula-popup__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.formula-popup__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d2129;
}

.formula-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.formula-category__header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
}

.formula-category__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
}

.formula-category__body {
  padding-left: 40rpx;
  padding-bottom: 16rpx;
}

.formula-item {
  display: block;
  font-size: 28rpx;
  color: #4e5969;
  line-height: 1.8;
  padding: 8rpx 0;
  background: #f7f8fa;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  font-family: monospace;
}
