<!--
  自定义导航栏组件
  适配 Skyline 渲染引擎
-->
<view class="navigation-bar" style="background: {{background}}; color: {{color}};">
  <!-- 占位元素，用于撑开页面内容，避免被导航栏遮挡 -->
  <view class="navigation-bar__placeholder" style="height: {{totalHeight}}px;"></view>
  
  <!-- 导航栏主体（固定定位） -->
  <view class="navigation-bar__fixed" style="background: {{background}}; color: {{color}};">
    <!-- 状态栏占位 -->
    <view class="navigation-bar__status-bar" style="height: {{statusBarHeight}}px;"></view>
    
    <!-- 导航栏内容区 -->
    <view class="navigation-bar__content" style="height: {{navBarHeight}}px;">
      <!-- 左侧区域 -->
      <view class="navigation-bar__left">
        <!-- 返回按钮 -->
        <view wx:if="{{showBack}}" class="navigation-bar__button" bindtap="handleBack">
          <view class="navigation-bar__icon navigation-bar__icon--back"></view>
        </view>
        
        <!-- 首页按钮 -->
        <view wx:if="{{showHome}}" class="navigation-bar__button" bindtap="handleHome">
          <view class="navigation-bar__icon navigation-bar__icon--home"></view>
        </view>
        
        <!-- 左侧自定义内容 -->
        <slot name="left"></slot>
      </view>
      
      <!-- 中间标题区域 -->
      <view class="navigation-bar__center">
        <block wx:if="{{title}}">
          <text class="navigation-bar__title">{{title}}</text>
        </block>
        <block wx:else>
          <slot name="center"></slot>
        </block>
      </view>
      
      <!-- 右侧区域 -->
      <view class="navigation-bar__right" bindtap="handleRightClick">
        <block wx:if="{{customRight}}">
          <slot name="right"></slot>
        </block>
      </view>
    </view>
  </view>
</view>
