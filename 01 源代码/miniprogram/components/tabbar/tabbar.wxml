<!--
  自定义TabBar组件 - 5个Tab动态渲染
-->
<view class="tab-bar" style="padding-bottom: {{safeBottom}}px;">
  <view
    wx:for="{{tabs}}"
    wx:key="index"
    class="tab-item {{selected === item.index ? 'active' : ''}}"
    bindtap="onTabChange"
    data-index="{{item.index}}"
  >
    <view class="tab-icon-wrapper">
      <t-icon 
        name="{{selected === item.index ? item.activeIcon : item.icon}}" 
        size="44rpx" 
        color="{{selected === item.index ? '#1664FF' : '#999999'}}"
      />
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
