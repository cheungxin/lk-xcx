/* 触发按钮 */
.draft-sheet-trigger {
  position: fixed;
  z-index: 10990;
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  backdrop-filter: blur(20rpx);
}

.draft-sheet-trigger--light {
  background: rgba(255, 255, 255, 0.94);
  border-color: rgba(255, 125, 0, 0.12);
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.12);
}

.draft-sheet-trigger--dark {
  background: rgba(19, 28, 47, 0.92);
  border-color: rgba(255, 180, 95, 0.16);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.2);
}

.draft-sheet-trigger--active {
  border-color: rgba(255, 125, 0, 0.28);
  box-shadow: 0 14rpx 34rpx rgba(255, 125, 0, 0.2);
}

.draft-sheet-trigger__icon-wrap {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.draft-sheet-trigger__dot {
  position: absolute;
  top: -4rpx;
  right: -6rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff7d00;
  border: 3rpx solid #ffffff;
}

.draft-sheet-trigger--dark .draft-sheet-trigger__dot {
  border-color: #131c2f;
}

/* 全屏草稿纸 - 覆盖整个屏幕但避开导航栏 */
.draft-sheet-fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 11500;
  display: flex;
  flex-direction: column;
  touch-action: none;
  user-select: none;
  -webkit-user-select: none;
  pointer-events: auto;
}

.draft-sheet-fullscreen__overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  touch-action: none;
  pointer-events: auto;
}

.draft-sheet-fullscreen--light .draft-sheet-fullscreen__overlay {
  background: rgba(255, 255, 255, 0.92);
}

.draft-sheet-fullscreen--dark .draft-sheet-fullscreen__overlay {
  background: rgba(0, 0, 0, 0.85);
}

/* 顶部工具栏 */
.draft-sheet-fullscreen__toolbar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: transparent;
  flex-shrink: 0;
  margin-top: calc(var(--status-bar-height, 0px) + 44px);
  pointer-events: auto;
}

.draft-sheet-fullscreen__toolbar-left,
.draft-sheet-fullscreen__toolbar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.draft-sheet-fullscreen__toolbar-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.draft-sheet-fullscreen__title {
  font-size: 32rpx;
  font-weight: 600;
}

.draft-sheet-fullscreen--light .draft-sheet-fullscreen__title {
  color: #1D2129;
}

.draft-sheet-fullscreen--dark .draft-sheet-fullscreen__title {
  color: #FFFFFF;
}

.draft-sheet-fullscreen__tool-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.draft-sheet-fullscreen--light .draft-sheet-fullscreen__tool-btn {
  background: rgba(255, 255, 255, 0.8);
}

.draft-sheet-fullscreen--dark .draft-sheet-fullscreen__tool-btn {
  background: rgba(255, 255, 255, 0.1);
}

.draft-sheet-fullscreen__tool-btn--disabled {
  opacity: 0.4;
}

/* 画布区域 */
.draft-sheet-fullscreen__canvas-wrap {
  position: relative;
  z-index: 2;
  flex: 1;
  width: 100%;
  overflow: hidden;
  touch-action: none;
  user-select: none;
  -webkit-user-select: none;
  pointer-events: auto;
}

.draft-sheet-fullscreen__canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  touch-action: none;
  pointer-events: auto;
  display: block;
}

.draft-sheet-fullscreen__placeholder {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  pointer-events: none;
}

.draft-sheet-fullscreen__placeholder-text {
  font-size: 28rpx;
  opacity: 0.5;
}

.draft-sheet-fullscreen--light .draft-sheet-fullscreen__placeholder-text {
  color: #1D2129;
}

.draft-sheet-fullscreen--dark .draft-sheet-fullscreen__placeholder-text {
  color: #FFFFFF;
}


