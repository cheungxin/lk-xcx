/* 我的页面样式 - 与首页保持一致 */

.page {
  min-height: 100vh;
  background: #f3f7fd;
  position: relative; 
}

/* 导航栏样式覆盖 - 确保初始透明 */
t-navbar {
  --td-navbar-bg-color: transparent;
}

.page-aura {
  position: fixed;
  border-radius: 50%;
  filter: blur(24rpx);
  z-index: 0;
}

.page-aura--top {
  top: -180rpx;
  left: -100rpx;
  width: 560rpx;
  height: 560rpx;
  background: radial-gradient(circle, rgba(179, 219, 255, 0.92) 0%, rgba(231, 244, 255, 0.24) 68%, rgba(243, 247, 253, 0) 100%);
}

.page-aura--side {
  top: 220rpx;
  right: -180rpx;
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle, rgba(211, 232, 255, 0.76) 0%, rgba(243, 247, 253, 0) 72%);
}

.page-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
  box-sizing: border-box;
}

.page-content {
  position: relative;
  z-index: 1;
  height: 100vh;
  box-sizing: border-box;
}

.nav-bar-placeholder {
  width: 100%;
  display: flex;
  align-items: center;
  padding-left: 32rpx;
  box-sizing: border-box;
}

.nav-bar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2F3442;
}

/* 用户信息卡片 */
.profile-header {
  position: relative;
  margin: 20rpx 24rpx 32rpx 24rpx;
}

.profile-header__bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #4B74FF 0%, #6B92FF 50%, #79ACFF 100%);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(75, 116, 255, 0.16);
}

.profile-header__bg::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -30rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.profile-header__bg::after {
  content: '';
  position: absolute;
  top: 20rpx;
  left: -50rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.profile-header__content {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx;
}

.profile-header__main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.profile-edit {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.profile-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: visible;
  flex-shrink: 0;
}

.profile-avatar__image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 8rpx 24rpx rgba(66, 106, 187, 0.3);
  background: #fff;
}

.profile-avatar__vip {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 165, 0, 0.4);
}

.profile-info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.profile-info__name {
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  display: block;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
  letter-spacing: 1rpx;
}

.profile-info__desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  font-weight: 400;
}

/* 练习数据统计卡片 */
.stats-card {
  margin: 0 24rpx;
  margin-bottom: 32rpx;
  padding: 32rpx 24rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(42, 77, 145, 0.04);
  border: 1rpx solid rgba(238, 242, 248, 0.8);
}

.stats-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stats-header__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stats-header__accent {
  width: 6rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #4B74FF 0%, #79B6FF 100%);
}

.stats-header__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2F3442;
}

.stats-header__right {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stats-header__more {
  font-size: 24rpx;
  color: #95A0B3;
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.stats-item__value {
  font-size: 40rpx;
  font-weight: 700;
  color: #4B74FF;
  margin-bottom: 8rpx;
  line-height: 1;
}

.stats-item__label {
  font-size: 22rpx;
  color: #95A0B3;
}

.stats-divider {
  width: 2rpx;
  height: 48rpx;
  background: #EEF2F8;
  flex-shrink: 0;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

.menu-section__title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 8rpx;
  margin-bottom: 16rpx;
}

.menu-section__accent {
  width: 6rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #4B74FF 0%, #79B6FF 100%);
}

.menu-section__title text {
  font-size: 28rpx;
  font-weight: 600;
  color: #2F3442;
}

.menu-card {
  overflow: hidden;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(42, 77, 145, 0.04);
  border: 1rpx solid rgba(238, 242, 248, 0.5);
}

.menu-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(79, 110, 197, 0.15);
}

.menu-arrow-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* TDesign Cell 样式覆盖 */
.menu-card t-cell {
  --td-cell-bg-color: transparent;
  --td-cell-border-color: #f1f4f9;
  --td-cell-title-color: #2F3442;
  --td-cell-note-color: #72809A;
  --td-cell-description-color: #72809A;
  --td-cell-vertical-padding: 26rpx; /* Restored to "just right" height */
  --td-cell-horizontal-padding: 32rpx;
  --td-cell-left-icon-color: transparent;
}

.menu-card t-cell:last-child {
  --td-cell-border-color: transparent;
}

/* 页面底部 */
.profile-footer {
  padding: 40rpx 0;
  text-align: center;
}

.profile-footer__text {
  font-size: 22rpx;
  color: #C9CDD4;
}

/* 反馈弹窗样式 */
.feedback-dialog {
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 90vh;
  overflow: hidden;
}

.feedback-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #F1F4F9;
}

.feedback-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2F3442;
}

.feedback-close {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feedback-content {
  padding: 32rpx 24rpx;
  max-height: calc(90vh - 100rpx);
  overflow-y: auto;
}

.feedback-label {
  display: block;
  font-size: 28rpx;
  color: #2F3442;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.feedback-required {
  color: #FF6B6B;
  margin-right: 4rpx;
}

/* 反馈类型选择 */
.feedback-type {
  margin-bottom: 32rpx;
}

.feedback-type-tabs {
  display: flex;
  gap: 16rpx;
}

.feedback-type-tab {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #F5F7FA;
  color: #72809A;
  font-size: 28rpx;
  transition: all 0.3s;
}

.feedback-type-tab.active {
  background: #EEF3FF;
  color: #4B74FF;
  font-weight: 600;
}

/* 建议输入 */
.feedback-input-wrap {
  margin-bottom: 32rpx;
  position: relative;
}

.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #F5F7FA;
  font-size: 28rpx;
  color: #2F3442;
  line-height: 1.6;
  box-sizing: border-box;
}

.feedback-placeholder {
  color: #C9CDD4;
  font-size: 26rpx;
}

.feedback-count {
  position: absolute;
  right: 24rpx;
  bottom: 16rpx;
  font-size: 24rpx;
  color: #C9CDD4;
}

/* 图片补充 */
.feedback-images {
  margin-bottom: 32rpx;
}

.feedback-images-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feedback-image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.feedback-image {
  width: 100%;
  height: 100%;
}

.feedback-image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.feedback-image-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #F5F7FA;
  border: 2rpx dashed #C9CDD4;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 提交按钮 */
.feedback-submit {
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}
