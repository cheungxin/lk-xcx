<view class="page">
  <view class="page-aura page-aura--top"></view>
  
  <scroll-view
    class="page-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    style="padding-top: {{safeTop}}px; padding-bottom: {{tabBarHeight}}rpx;"
  >
    <!-- 页面头部 -->
    <view class="page-header">
      <view class="page-header__title">
        <text class="page-header__icon">📖</text>
        <text>背诵模式</text>
      </view>
      <text class="page-header__desc">知识点记忆与巩固复习</text>
    </view>

    <!-- 今日进度 -->
    <view class="progress-card">
      <view class="progress-card__header">
        <text class="progress-card__title">今日背诵进度</text>
        <text class="progress-card__count">{{todayProgress.completed}}/{{todayProgress.total}}</text>
      </view>
      <view class="progress-card__bar">
        <view class="progress-card__fill" style="width: {{todayProgress.completed / todayProgress.total * 100}}%;"></view>
      </view>
      <view class="progress-card__actions">
        <view class="progress-card__btn" bindtap="onStartMemorize">
          <t-icon name="play-circle" size="32rpx" color="#1664FF" />
          <text>继续背诵</text>
        </view>
        <view class="progress-card__btn" bindtap="onReviewTap">
          <t-icon name="refresh" size="32rpx" color="#ED7B2F" />
          <text>待巩固 {{memoryStats.learning}}</text>
        </view>
      </view>
    </view>

    <!-- 记忆统计 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-item__num">{{memoryStats.mastered}}</text>
        <text class="stat-item__label">已掌握</text>
      </view>
      <view class="stat-item">
        <text class="stat-item__num stat-item__num--orange">{{memoryStats.learning}}</text>
        <text class="stat-item__label">学习中</text>
      </view>
      <view class="stat-item">
        <text class="stat-item__num stat-item__num--blue">{{memoryStats.new}}</text>
        <text class="stat-item__label">待学习</text>
      </view>
    </view>

    <!-- 背诵分类 -->
    <view class="section">
      <view class="section__header">
        <text class="section__title">背诵分类</text>
      </view>
      <view class="category-list">
        <view
          class="category-card"
          wx:for="{{categories}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onCategoryTap"
        >
          <view class="category-card__icon" style="background: {{item.bgColor}};">
            <t-icon name="{{item.icon}}" size="48rpx" color="{{item.iconColor}}" />
          </view>
          <view class="category-card__info">
            <text class="category-card__name">{{item.name}}</text>
            <text class="category-card__desc">{{item.desc}}</text>
          </view>
          <view class="category-card__right">
            <text class="category-card__count">{{item.count}}个</text>
            <t-icon name="chevron-right" size="28rpx" color="#C0C4CC" />
          </view>
        </view>
      </view>
    </view>

    <!-- 背诵提示 -->
    <view class="tip-card">
      <t-icon name="info-circle" size="32rpx" color="#8B5CF6" />
      <text class="tip-card__text">基于艾宾浩斯遗忘曲线，科学安排复习计划，高效记忆知识点</text>
    </view>
  </scroll-view>

  <tabbar selected="{{3}}" />
</view>
