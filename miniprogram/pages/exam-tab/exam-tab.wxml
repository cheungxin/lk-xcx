<view class="page">
  <view class="page-aura page-aura--top"></view>
  
  <scroll-view
    class="page-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    style="padding-top: {{safeTop}}px; padding-bottom: {{tabBarHeight}}rpx;"
  >
    <!-- 页面头部 -->
    <view class="page-header">
      <view class="page-header__title">
        <text class="page-header__icon">📊</text>
        <text>估分模式</text>
      </view>
      <text class="page-header__desc">模拟真实考试环境，精准估分</text>
    </view>

    <!-- 快速入口 -->
    <view class="section">
      <view class="section__header">
        <text class="section__title">快速估分</text>
      </view>
      <view class="quick-grid">
        <view
          class="quick-card"
          wx:for="{{quickEntries}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onQuickEntryTap"
        >
          <view class="quick-card__icon" style="background: {{item.bgColor}};">
            <t-icon name="{{item.icon}}" size="48rpx" color="{{item.iconColor}}" />
          </view>
          <view class="quick-card__info">
            <text class="quick-card__title">{{item.title}}</text>
            <text class="quick-card__desc">{{item.desc}}</text>
          </view>
          <t-icon name="chevron-right" size="32rpx" color="#C0C4CC" />
        </view>
      </view>
    </view>

    <!-- 历年试卷 -->
    <view class="section">
      <view class="section__header">
        <text class="section__title">历年试卷</text>
        <view class="section__more" bindtap="onHistoryTap">
          <text>估分记录</text>
          <t-icon name="chevron-right" size="24rpx" color="#9AA3B2" />
        </view>
      </view>
      
      <view class="paper-list">
        <view
          class="paper-card"
          wx:for="{{paperList}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onPaperTap"
        >
          <view class="paper-card__left">
            <view class="paper-card__tag {{item.tag === '国考' ? 'paper-card__tag--blue' : item.tag === '省考' ? 'paper-card__tag--orange' : 'paper-card__tag--green'}}">
              {{item.tag}}
            </view>
            <text class="paper-card__title">{{item.title}}</text>
            <view class="paper-card__meta">
              <text>{{item.questions}}题</text>
              <text class="paper-card__dot">·</text>
              <text>{{item.duration}}分钟</text>
              <text class="paper-card__dot">·</text>
              <text>{{item.difficulty}}</text>
            </view>
          </view>
          <view class="paper-card__right">
            <view wx:if="{{item.hasDone}}" class="paper-card__score">
              <text class="paper-card__score-num">{{item.score}}</text>
              <text class="paper-card__score-label">分</text>
            </view>
            <view wx:else class="paper-card__action">
              <text>开始</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 估分提示 -->
    <view class="tip-card">
      <t-icon name="info-circle" size="32rpx" color="#4B74FF" />
      <text class="tip-card__text">估分模式下严格计时，交卷后可查看详细解析和各板块正确率</text>
    </view>
  </scroll-view>

  <tabbar selected="{{1}}" />
</view>
