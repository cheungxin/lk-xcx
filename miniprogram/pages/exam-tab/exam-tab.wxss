/* 估分Tab页样式 */

.page {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
}

.page-aura {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  pointer-events: none;
  z-index: 0;
}

.page-aura--top {
  background: linear-gradient(180deg, #E8EEFF 0%, #F5F7FA 100%);
}

.page-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
  box-sizing: border-box;
}

.page-header {
  padding: 32rpx 32rpx 24rpx;
}

.page-header__title {
  display: flex;
  align-items: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.page-header__icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.page-header__desc {
  font-size: 26rpx;
  color: #7F8C8D;
  margin-left: 48rpx;
}

.section {
  margin: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.section__more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #9AA3B2;
}

/* 快速入口 */
.quick-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #FAFBFD;
  transition: background 0.2s;
}

.quick-card:active {
  background: #EEF2FF;
}

.quick-card__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.quick-card__info {
  flex: 1;
}

.quick-card__title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  display: block;
  margin-bottom: 4rpx;
}

.quick-card__desc {
  font-size: 22rpx;
  color: #9AA3B2;
}

/* 试卷列表 */
.paper-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.paper-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #FAFBFD;
  transition: background 0.2s;
}

.paper-card:active {
  background: #EEF2FF;
}

.paper-card__left {
  flex: 1;
  margin-right: 16rpx;
}

.paper-card__tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.paper-card__tag--blue {
  background: #EEF2FF;
  color: #4B74FF;
}

.paper-card__tag--orange {
  background: #FFF7E6;
  color: #ED7B2F;
}

.paper-card__tag--green {
  background: #F0FFF4;
  color: #00A870;
}

.paper-card__title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  display: block;
  margin-bottom: 8rpx;
}

.paper-card__meta {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #9AA3B2;
}

.paper-card__dot {
  margin: 0 8rpx;
  color: #D8DCE6;
}

.paper-card__right {
  flex-shrink: 0;
}

.paper-card__score {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4B74FF, #6C8EFF);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.paper-card__score-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.paper-card__score-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
}

.paper-card__action {
  padding: 12rpx 28rpx;
  background: #1664FF;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 提示卡片 */
.tip-card {
  margin: 24rpx 32rpx 32rpx;
  padding: 20rpx 24rpx;
  background: #EEF2FF;
  border-radius: 16rpx;
  display: flex;
  align-items: flex-start;
}

.tip-card__text {
  font-size: 22rpx;
  color: #4B74FF;
  margin-left: 12rpx;
  line-height: 1.5;
}
