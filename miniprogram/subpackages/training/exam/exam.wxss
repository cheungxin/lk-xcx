.exam-page {
  min-height: 100vh;
  background: #f7f8fa;
}

.select-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 48rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7f8fa 100%);
}

.select-hero__icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #eef3ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.select-hero__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d2129;
  margin-bottom: 12rpx;
}

.select-hero__desc {
  font-size: 28rpx;
  color: #86909c;
  text-align: center;
  line-height: 1.6;
}

.paper-list {
  padding: 0 32rpx calc(32rpx + env(safe-area-inset-bottom));
}

.paper-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.paper-card__top {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.paper-card__name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d2129;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.paper-card__info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.paper-card__meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #86909c;
}

.paper-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f2f3f5;
}

.paper-card__sections {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.paper-card__section-tag {
  font-size: 24rpx;
  color: #86909c;
  padding: 6rpx 16rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
}
