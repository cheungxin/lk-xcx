page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.shenlun-page {
  flex: 1;
  height: 100%;
  width: 100%;
  background: #f5f7fb;
  display: flex;
  flex-direction: column;
}

.shenlun-scroll {
  flex: 1;
  height: 100%;
  width: 100%;
}

.shenlun-content {
  padding: 24rpx 24rpx 220rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.summary-card,
.material-card,
.question-card,
.answer-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 14rpx 38rpx rgba(20, 56, 110, 0.06);
}

.summary-card {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #ffffff 100%);
}

.summary-card__main {
  flex: 1;
}

.summary-card__eyebrow {
  display: block;
  font-size: 22rpx;
  color: #7e8ca2;
}

.summary-card__title {
  display: block;
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #243042;
}

.summary-card__subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #96a2b5;
}

.summary-card__timer {
  min-width: 176rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(22, 100, 255, 0.08);
  text-align: right;
}

.summary-card__timer-label {
  display: block;
  font-size: 22rpx;
  color: #6f7f94;
}

.summary-card__timer-value {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1664ff;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-head__title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #243042;
}

.section-head__subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9aa5b5;
}

.material-card,
.question-card,
.answer-card {
  padding: 30rpx 28rpx;
}

.material-card__toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #5f6b7f;
}

.material-card__body {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.material-card__text,
.question-card__text,
.answer-card__textarea {
  white-space: pre-wrap;
  line-height: 1.8;
  font-size: 28rpx;
  color: #354154;
}

.question-card__meta,
.answer-card__tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.question-card__meta {
  margin-top: 20rpx;
}

.question-card__title {
  display: block;
  margin-top: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #243042;
}

.question-card__text {
  display: block;
  margin-top: 16rpx;
}

.answer-card__count {
  font-size: 26rpx;
  font-weight: 600;
  color: #1664ff;
}

.answer-card__count--danger {
  color: #e34d59;
}

.answer-card__textarea {
  width: 100%;
  min-height: 340rpx;
  margin-top: 22rpx;
  padding: 0;
}

.answer-card__tags {
  margin-top: 18rpx;
}

.question-tabs {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.question-tab {
  min-width: 136rpx;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(20, 56, 110, 0.05);
  text-align: center;
}

.question-tab--done {
  background: #eef8f1;
}

.question-tab--active {
  background: linear-gradient(135deg, #1664ff 0%, #4f8dff 100%);
}

.question-tab__text {
  font-size: 24rpx;
  font-weight: 600;
  color: #5f6b7f;
}

.question-tab--active .question-tab__text {
  color: #ffffff;
}

.shenlun-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 18rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 36rpx rgba(19, 40, 72, 0.08);
}

.shenlun-footer__group {
  display: flex;
  gap: 18rpx;
  flex: 1;
}

.shenlun-footer__group > t-button,
.shenlun-footer > t-button {
  flex: 1;
}
