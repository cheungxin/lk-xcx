page {
  height: 100%;
  background: #f4f7fc;
}

.report-page {
  min-height: 100vh;
  background: #f4f7fc;
  display: flex;
  flex-direction: column;
}

.report-scroll {
  flex: 1;
  height: 0;
}

.report-content {
  padding: 24rpx 24rpx 220rpx;
}

.report-hero {
  position: relative;
  margin-bottom: 24rpx;
  padding: 40rpx 0 20rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #2f63ff 0%, #4f88ff 100%);
  overflow: hidden;
}

/* 背景虚化装饰 */
.report-hero::before {
  content: '';
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  filter: blur(60rpx);
  border-radius: 50%;
  top: -100rpx;
  right: -100rpx;
}

.report-hero__card {
  position: relative;
  z-index: 1;
  margin: 0 32rpx;
  padding: 40rpx 32rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(27, 60, 130, 0.12);
}

.report-hero__header {
  margin-bottom: 40rpx;
}

.report-mode-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: #eef3ff;
  color: #1664ff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 99rpx;
}

.report-paper-title {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2129;
  line-height: 1.4;
}

.report-hero__main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.score-box {
  flex: 1.2;
}

.score-box__val {
  display: flex;
  align-items: baseline;
}

.score-box__num {
  font-size: 88rpx;
  font-weight: 800;
  color: #1664ff;
  line-height: 1;
}

.score-box__total {
  font-size: 28rpx;
  color: #86909c;
  margin-left: 8rpx;
}

.score-box__label {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #86909c;
}

.hero-divider {
  width: 2rpx;
  height: 80rpx;
  background: #f2f3f5;
  margin: 0 32rpx;
}

.hero-stats {
  flex: 2;
  display: flex;
  justify-content: space-around;
}

.hero-stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-stat-block__val {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2129;
}

.hero-stat-block__label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #86909c;
}

.report-hero__footer {
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid #f2f3f5;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-headline {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-right: 24rpx;
}

.hero-headline__text {
  font-size: 24rpx;
  color: #4e5969;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.hero-retry-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f2f3f5;
  border-radius: 99rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1664ff;
}

.hero-retry-btn:active {
  background: #e5e6eb;
}

.report-card {
  padding: 30rpx 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 38rpx rgba(20, 56, 110, 0.06);
}

.report-card + .report-card {
  margin-top: 24rpx;
}

.report-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.report-card__header--stacked {
  align-items: flex-start;
  flex-direction: column;
}

.report-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.report-card__desc {
  font-size: 24rpx;
  color: #93a1b7;
}

.report-tree-shell {
  margin-top: 24rpx;
  border-radius: 24rpx;
  background: #f7f9fd;
  overflow: hidden;
}

.report-tree-shell .tree-container {
  background: transparent;
  padding: 8rpx 0;
}

.report-tree-shell .tree-item {
  width: calc(100% - 52rpx);
  padding: 24rpx 0;
  background: transparent;
}

.report-tree-shell .tree-item:active {
  background: rgba(59, 120, 255, 0.05);
}

.report-tree-shell .tree-item-line {
  width: calc(100% - 60rpx);
  background: #e6edf8;
}

.report-tree-shell .children-level {
  padding-left: 36rpx;
}

.report-tree-shell .item-title {
  white-space: normal;
  line-height: 1.45;
}

.report-tree-shell .item-desc {
  margin-top: 8rpx;
  color: #7b889e;
}

.report-card__link {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.report-card__link-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b78ff;
}

.report-stats {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  margin-top: 28rpx;
  border-radius: 24rpx;
  background: #f7f9fd;
  overflow: hidden;
}

.report-stat {
  min-height: 132rpx;
  padding: 22rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  position: relative;
}

.report-stat::after {
  content: '';
  position: absolute;
  top: 24rpx;
  right: 0;
  width: 1rpx;
  height: calc(100% - 48rpx);
  background: #e5ebf5;
}

.report-stat:last-child::after {
  display: none;
}

.report-stat__label {
  font-size: 22rpx;
  color: #98a3b7;
}

.report-stat__value {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #2a3342;
  text-align: center;
  word-break: break-word;
}

.report-stat--success .report-stat__value {
  color: #00a870;
}

.report-stat--danger .report-stat__value {
  color: #e34d59;
}

.report-stat--warning .report-stat__value {
  color: #ff7d00;
}

.report-stat--accent .report-stat__value {
  color: #3b78ff;
}

.section-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.section-item {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #f7f9fd;
}

.section-item__badge {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b78ff 0%, #5fa3ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
}

.section-item__body {
  flex: 1;
  min-width: 0;
}

.section-item__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-item__name {
  font-size: 30rpx;
  font-weight: 700;
  color: #253041;
  word-break: break-word;
}

.section-item__action {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.section-item__action-text {
  font-size: 24rpx;
  color: #8d9bb1;
}

.section-item__meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8d9bb1;
}

.section-item__track {
  margin-top: 16rpx;
  height: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #e6edf8;
}

.section-item__bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #3b78ff 0%, #61b2ff 100%);
}

.report-empty {
  flex: 1;
  padding: 120rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.report-empty__icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #eef3ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-empty__title {
  display: block;
  margin-top: 28rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #243042;
}

.report-empty__desc {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #8d99ac;
}

.report-empty__button {
  min-width: 248rpx;
  margin-top: 32rpx;
  padding: 24rpx 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3b78ff 0%, #4d8bff 100%);
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.report-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 18rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 36rpx rgba(19, 40, 72, 0.08);
}

.report-footer__button {
  flex: 1;
  min-height: 96rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-footer__button--ghost {
  background: #ffffff;
  border: 2rpx solid #d6deeb;
}

.report-footer__button--primary {
  background: linear-gradient(135deg, #3b78ff 0%, #4c8cff 100%);
}

.report-footer__button--disabled {
  opacity: 0.45;
}

.report-footer__button-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.report-footer__button-text--ghost {
  color: #253041;
}
