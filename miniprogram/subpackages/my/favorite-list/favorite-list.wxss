/* 收藏题目列表页样式 */
.page-container {
  min-height: 100vh;
  background-color: #F6F6F6;
  padding-bottom: 40rpx;
}

/* 题目列表容器 */
.question-list {
  padding: 32rpx;
}

/* 收藏卡片样式 */
.question-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease-in-out;
}

.question-card:active {
  transform: scale(0.98);
  background-color: #FAFAFA;
}

/* 头部显示区域 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.type-tag {
  margin-right: 12rpx;
}

.add-time {
  font-size: 24rpx;
  color: #95A0B3;
}

/* 题干内容展示 */
.card-content {
  margin-bottom: 32rpx;
}

.stem-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #2F3442;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 底部操作与统计 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.fav-info {
  display: flex;
  align-items: center;
}

.fav-text {
  font-size: 26rpx;
  color: #FF5A5A;
  margin-left: 8rpx;
}

.action-hint {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #95A0B3;
}

.action-hint t-icon {
  margin-left: 4rpx;
}

/* 空状态容器 */
.empty-wrapper {
  padding-top: 300rpx;
  background-color: #F6F6F6;
}
