.font-size-selector {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.font-size-selector__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #e5e6eb;
}

.font-size-selector__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d2129;
}

.font-size-selector__close {
  padding: 8rpx;
}

.font-size-selector__options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.font-size-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.25s ease;
}

.font-size-option--active {
  background: #eef4ff;
  border-color: #1664ff;
}

.font-size-option__preview {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  color: #1d2129;
  font-weight: 500;
}

.font-size-option__label {
  font-size: 24rpx;
  color: #4e5969;
  font-weight: 500;
}

.font-size-option--active .font-size-option__label {
  color: #1664ff;
  font-weight: 600;
}

.font-size-option__check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
}

.font-size-selector__tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #86909c;
  line-height: 1.5;
}
