<!--
  全局组件 - 空状态与加载态
-->
<view class="empty-state">
  <!-- 加载中 -->
  <view wx:if="{{type === 'loading'}}" class="empty-state__loading">
    <view class="loading-spinner">
      <view class="loading-spinner__dot"></view>
      <view class="loading-spinner__dot"></view>
      <view class="loading-spinner__dot"></view>
    </view>
    <text class="empty-state__title">{{title || '加载中...'}}</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{type === 'empty'}}" class="empty-state__content">
    <view class="empty-state__icon">
      <t-icon wx:if="{{icon}}" name="{{icon}}" size="{{imageHeight}}rpx" color="#C8CDD8" />
      <image wx:else class="empty-state__image" mode="aspectFit" style="width: {{imageHeight}}rpx; height: {{imageHeight}}rpx;"
        src="data:image/svg+xml;base64,"
      />
    </view>
    <text class="empty-state__title">{{title}}</text>
    <text class="empty-state__desc" wx:if="{{description}}">{{description}}</text>
  </view>

  <!-- 错误 -->
  <view wx:elif="{{type === 'error' || type === 'network'}}" class="empty-state__content">
    <view class="empty-state__icon">
      <t-icon name="error-circle" size="{{imageHeight}}rpx" color="#E34D59" />
    </view>
    <text class="empty-state__title">{{title || '出错了'}}</text>
    <text class="empty-state__desc" wx:if="{{description}}">{{description}}</text>
    <view wx:if="{{showRetry}}" class="empty-state__retry" bindtap="onRetry">
      <text>{{retryText}}</text>
    </view>
  </view>
</view>
