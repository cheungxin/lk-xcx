/* 树节点容器 */
.tree-node {
  width: 100%;
  text-align: left;
}

/* 树节点包装器 */
.tree-item-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* 树节点主体 */
.tree-item {
  width: 92%;
  margin: 0 auto;
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  margin-bottom: 10rpx;
  background-color: #fff;
  transition: background-color 0.3s ease;
}

.tree-item:active {
  background-color: #f5f5f5;
}

/* 展开/收起图标区域 */
.tree-item-icon {
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.node-toggle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.node-toggle--close {
  background: #EBF1FA;
}

.node-toggle--open {
  background: #4B74FF;
  box-shadow: 0 4rpx 12rpx rgba(75, 116, 255, 0.25);
}

.node-toggle__icon {
  position: relative;
  width: 20rpx;
  height: 3.5rpx;
  background: #4B74FF;
  border-radius: 999rpx;
  transition: all 0.3s ease;
}

.node-toggle--open .node-toggle__icon {
  background: #FFFFFF;
}

.node-toggle--close .node-toggle__icon::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 20rpx;
  height: 3.5rpx;
  background: #4B74FF;
  border-radius: 999rpx;
  transform: rotate(90deg);
}

.node-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #D7DEE8;
}

/* 节点内容区域 */
.tree-item-content {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.item-title {
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  color: #2F3442;
  font-weight: 600;
  line-height: 1.5;
}

.item-desc {
  font-size: 24rpx;
  color: #72809A;
  margin-top: 6rpx;
  line-height: 1.4;
  font-weight: 500;
}

/* 进入箭头区域 */
.tree-item-entry {
  width: 72rpx;
  min-width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  position: relative; /* For tooltip positioning */
}

.navigation-entry {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  position: relative;
}

.navigation-entry__link {
  display: flex;
  align-items: center;
  justify-content: center;
}

.navigation-entry__link-icon {
  font-size: 28rpx;
  color: #8b96a9;
}

.navigation-entry__fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.select-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.floating-continue-tooltip {
  position: absolute;
  top: -64rpx;
  right: 12rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #ffffff;
  text-align: center;
  background: #4B4B4B;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  white-space: nowrap;
  font-weight: 500;
  z-index: 20;
  animation: bounceTooltip 2s infinite ease-in-out;
}

@keyframes bounceTooltip {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.floating-continue-tooltip__arrow {
  position: absolute;
  left: 50%;
  bottom: -8rpx;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid #4B4B4B;
}

.navigation-entry:active {
  opacity: 0.75;
}

/* 分隔线 */
.tree-item-line {
  width: calc(100% - 40rpx);
  margin-left: auto;
  height: 1.5rpx;
  background-color: #F0F4FA;
}

/* 子节点缩进 */
.children-level {
  width: 100%;
  padding-left: 32rpx;
  box-sizing: border-box;
}

.children-level .tree-item {
  padding: 20rpx 0;
  margin-bottom: 0;
}

.children-level .item-title {
  font-size: 28rpx;
  font-weight: 500;
}

.children-level .tree-item-line {
  width: calc(100% - 20rpx);
}

/* 展开状态样式 */
.item-open {
  background-color: #FFFFFF;
}

/* 收起状态样式 */
.item-close {
  background-color: #FFFFFF;
}
.item-selectable:active {
  background-color: rgba(75, 116, 255, 0.05);
}
